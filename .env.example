# GitHub App credentials (from https://github.com/settings/apps)
APP_ID=
PRIVATE_KEY_PATH=
WEBHOOK_SECRET=

# LLM provider credentials (set one)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional: override webhook proxy for local dev
# WEBHOOK_PROXY_URL=https://smee.io/your-channel

# Optional: Docs portal revalidation (set both to enable instant refresh)
# PORTAL_URL=https://docs.your-domain.com
# PORTAL_REVALIDATE_SECRET=
